#!/usr/bin/env bash
set -euo pipefail

COMMAND="${1:-apply}"
SCRIPT_PATH="${BASH_SOURCE[0]}"

while [[ -L "$SCRIPT_PATH" ]]; do
  SCRIPT_DIR="$(cd -P "$(dirname "$SCRIPT_PATH")" && pwd)"
  SCRIPT_PATH="$(readlink "$SCRIPT_PATH")"

  [[ "$SCRIPT_PATH" != /* ]] && SCRIPT_PATH="$SCRIPT_DIR/$SCRIPT_PATH"
done

REPO_DIR="$(cd -P "$(dirname "$SCRIPT_PATH")" && pwd)"

OS="$(uname -s | tr '[:upper:]' '[:lower:]')"

log() {
  printf '[dotfiles] %s\n' "$*" >&2
}

abort() {
  printf '[dotfiles] ERROR: %s\n' "$*" >&2
  exit 1
}

has() {
  command -v "$1" >/dev/null 2>&1
}

macos() {
  local formulae=(
    atuin
    bat
    carapace
    fnm
    htop
    neovim
    nushell
    pyenv
    sesh
    starship
    stow
    topgrade
    tree-sitter-cli
    yazi
    zoxide
  )

  local casks=(
    ghostty
  )

  has brew || abort "Homebrew is not installed."

  log "Updating Homebrew..."
  brew update

  log "Installing formulae: ${formulae[*]}"
  brew install "${formulae[@]}"

  log "Installing casks: ${casks[*]}"
  brew install --cask "${casks[@]}"
}

nixos() {
  log "Rebuilding NixOS configuration..."
  sudo nixos-rebuild switch --flake "$REPO_DIR/nix#$(hostname)"
}

bootstrap() {
  case "$OS" in
    darwin) macos ;;
    linux) nixos ;;
    *) abort "Unsupported OS: $OS" ;;
  esac

  apply
}

dotfile_name() {
  local name="$1"
  printf '%s\n' "${name/#dot-/.}"
}

stow_target_path() {
  local rel="$1"
  local out=""
  local part

  IFS=/ read -ra parts <<< "$rel"

  for part in "${parts[@]}"; do
    [[ -n "$out" ]] && out+="/"
    out+="$(dotfile_name "$part")"
  done

  printf '%s/%s\n' "$HOME" "$out"
}

remove_conflicting_symlinks() {
  local dir="$1"
  local source_root="$dir/home"
  local source target rel source_real target_real

  [[ -d "$source_root" ]] || return 0

  while IFS= read -r -d '' source; do
    rel="${source#"$source_root"/}"
    target="$(stow_target_path "$rel")"

    [[ -L "$target" ]] || continue

    source_real="$(readlink -f "$source" 2>/dev/null || true)"
    target_real="$(readlink -f "$target" 2>/dev/null || true)"

    if [[ -z "$target_real" || "$source_real" != "$target_real" ]]; then
      log "Removing conflicting symlink: $target -> $(readlink "$target")"
      rm "$target"
    fi
  done < <(find "$source_root" \( -type f -o -type l \) -print0)
}

apply() {
  printf '%s\n' \
    "$REPO_DIR/stow" \
    "$REPO_DIR/stow/os/$OS" \
    "$REPO_DIR/stow/os/$OS/distro/$DISTRO" |
    while IFS= read -r dir; do
      [[ -d "$dir/home" ]] || continue

      log "Preparing $dir"
      remove_conflicting_symlinks "$dir"

      log "Stowing $dir"
      stow -d "$dir" -t "$HOME" -R --adopt --no-folding --dotfiles home
    done

  log "Apply complete."
}

update() {
  case "$OS:$DISTRO" in
    linux:nixos)
      log "Updating NixOS flake..."
      nix flake update "$REPO_DIR/nix#desktop"

      nixos
      ;;
    *)
      has topgrade || abort "topgrade is not installed."
      topgrade
      ;;
  esac

  log "Update complete."
}

case "$COMMAND" in
  bootstrap) bootstrap ;;
  apply) apply ;;
  update) update ;;
  *) abort "Usage: $0 [bootstrap|apply|update]" ;;
esac

